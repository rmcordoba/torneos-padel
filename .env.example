# Database
DATABASE_URL="postgresql://padel:padel_secret@localhost:5432/torneos_padel"
# Conexión directa para migraciones (prisma migrate). En local: igual a DATABASE_URL.
# En Neon: usar el connection string "direct" (sin -pooler) acá y el pooled en DATABASE_URL.
DIRECT_URL="postgresql://padel:padel_secret@localhost:5432/torneos_padel"

# Auth.js v5
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# OAuth providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Torneos de Pádel"

# Email (Resend — https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="PadelPro <noreply@tudominio.com>"

# Mercado Pago (Checkout Pro). Access Token de TEST o producción.
# El webhook necesita URL pública (deploy o túnel tipo ngrok); MP no llega a localhost.
# notification_url = ${NEXT_PUBLIC_APP_URL}/api/webhooks/mercadopago
MP_ACCESS_TOKEN=""
# Opcional: secreto para validar la firma del webhook (x-signature)
MP_WEBHOOK_SECRET=""

# Datos de pago manual mostrados en /dashboard/facturacion (opcional)
BILLING_TRANSFER_INFO=""

# Cron jobs (/api/cron/*). OBLIGATORIO en producción: sin esto los endpoints
# de cron devuelven 401. Vercel Cron lo envía automáticamente como
# Authorization: Bearer <CRON_SECRET>. Generar con: openssl rand -hex 32
CRON_SECRET=""
